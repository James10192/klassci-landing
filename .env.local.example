# PostHog (project 1508541 — same as ADC)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Disable analytics in dev (set to "true" to skip)
NEXT_PUBLIC_DISABLE_ANALYTICS=true

# Tenant lookup proxy — points to Laravel KLASSCIv2 API
TENANT_LOOKUP_API_URL=https://docs.klassci.com/api/tenant-lookup
TENANT_LOOKUP_API_TOKEN=

# Contact form delivery (required in Vercel Preview and Production)
WEB3FORMS_ACCESS_KEY=

# Production prerequisite: apply a Vercel WAF rate-limit rule to POST /api/contact.
# The route's in-memory limiter is only a bounded, per-instance fallback.

# Optional legacy fallback if a compatible Laravel endpoint is restored
CONTACT_DEMO_URL=

# Laravel host for docs / api-reference / changelog rewrites (next.config.mjs)
# Before DNS cutover, docs.klassci.com must be created on cpanel as an A record
# pointing to the same Laravel instance that currently serves klassci.com
# (91.234.194.113).
LARAVEL_DOCS_HOST=https://docs.klassci.com

# Site URL (used for canonical, OG, sitemap)
NEXT_PUBLIC_SITE_URL=https://klassci.com
